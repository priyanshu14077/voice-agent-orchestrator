# Server Configuration
PORT=8080
ORCHESTRATOR_PORT=8090
ORCHESTRATOR_WS_URL=ws://localhost:8090

# LLM (Groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Speech-to-Text (Deepgram)
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_MODEL=nova-2
DEEPGRAM_SAMPLE_RATE=8000
DEEPGRAM_ENCODING=linear16

# Text-to-Speech (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Voice Activity Detection
VAD_URL=http://localhost:8000
VAD_TIMEOUT_MS=1500
VAD_SILENCE_MS=500

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_agent

# Redis
REDIS_URL=redis://localhost:6379

# WhatsApp (Meta Business Cloud)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token

# Node Environment
NODE_ENV=development